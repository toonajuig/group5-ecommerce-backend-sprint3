# =========================================================================
# CART API TESTS (Requires @authToken)
# =========================================================================

### 1. Get Current User's Cart
GET {{baseUrl}}/carts

### 2. Add an Item to Cart
POST {{baseUrl}}/carts
Content-Type: application/json

{
  "productId": "6a1914e63b9010b699421c84",
  "quantity": 2
}

### 3. Update Cart Item Quantity (Delta adjustments: use positive or negative values)
PATCH {{baseUrl}}/carts/quantity/6a1914e63b9010b699421c84
Content-Type: application/json

{
  "quantity": 3
}

### 4. Edit Cart Item Quantity (Direct Override / Set to 0 to delete item)
POST {{baseUrl}}/carts/edit
Content-Type: application/json

{
  "productId": "6a1914e63b9010b699421c84",
  "quantity": 0
}

### 5. Remove Single Item From Cart (Drop Completely)
POST {{baseUrl}}/carts/remove
Content-Type: application/json

{
  "productId": "6a1914e63b9010b699421c84"
}

### 6. Clear Entire Cart Array
POST {{baseUrl}}/carts/clear

# =========================================================================
# ORDER API TESTS (Requires @authToken)
# =========================================================================

### 7. Create New Order From Cart Details (Purges Cart and sets Order to Pending)
# @name checkoutRequest
POST {{baseUrl}}/orders/checkout
Content-Type: application/json

{
  "paymentMethod": "Bank transfer"
}

### Grab the dynamic order ID generated from Test #7 above automatically
@realOrderId = {{checkoutRequest.response.body.data._id}}

### 8. Get All System Orders (Admin view - sorted newest first)
GET {{baseUrl}}/orders/all

### 9. Update order detail & change order status to Paid (Deducts product stock)
PUT {{baseUrl}}/orders/6a26c164e9382086d5f2c562
Content-Type: application/json

{
  "status": "Paid"
}

### 10. Admin cancels order (Returns database stock to shelf because status was Paid)
# NOTE: "Canceled" must be spelled with one 'L' to match your updated schema enum validation!
PUT {{baseUrl}}/orders/{{realOrderId}}
Content-Type: application/json

{
  "status": "Canceled"
}
